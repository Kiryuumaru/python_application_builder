{
  "App": {
    "Name": "MultiConfig Demo",
    "Version": "1.0.0",
    "Environment": "development"
  },
  "Database": {
    "Host": "localhost",
    "Port": 5432,
    "Name": "demo_db",
    "MaxConnections": 10
  },
  "Features": {
    "DarkMode": true,
    "BetaAPI": false,
    "Caching": true,
    "Logging": true
  },
  "Monitoring": {
    "Enabled": true,
    "IntervalSeconds": 3,
    "ReportIntervalSeconds": 6
  }
}
